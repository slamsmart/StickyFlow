{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/ABSOLUTE/PATH/TO/YOUR/PROJECT"
      ]
    },
    "git": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-server-git",
        "--repository",
        "/ABSOLUTE/PATH/TO/YOUR/PROJECT"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ]
    }
  }
}
